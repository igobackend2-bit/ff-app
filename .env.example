# ════════════════════════════════════════════════════
# QuickCart — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# ════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://quickcart.in
NEXT_PUBLIC_APP_NAME=QuickCart
NEXT_PUBLIC_DEFAULT_CITY=Mumbai

# ── Database (PostgreSQL) ────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://quickcart:password@localhost:5432/quickcart

# ── Auth (NextAuth v5) ────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (for one-tap sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OTP / SMS (MSG91) ─────────────────────────────────
SMS_PROVIDER=msg91
MSG91_API_KEY=
MSG91_SENDER_ID=QKKCRT
MSG91_TEMPLATE_ID=

# ── Redis (Upstash) ───────────────────────────────────
# Used for OTP rate limiting and session cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Payments (Razorpay) ───────────────────────────────
# IMPORTANT: Key ID is public-safe. Key Secret is server-only.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Media (Cloudinary) ────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Maps (Google) ─────────────────────────────────────
# Restrict this key to Maps JavaScript API + Geocoding API only
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Search (Algolia) ──────────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=
ALGOLIA_PRODUCTS_INDEX=quickcart_products

# ── Push Notifications (Firebase) ────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
# Stringified JSON of Firebase Admin service account
FIREBASE_ADMIN_SDK_JSON=

# ── Analytics (PostHog) ───────────────────────────────
# Loaded via Partytown — never on main thread
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Monitoring (Sentry) ───────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=quickcart

# ── CSRF ──────────────────────────────────────────────
# Generate: openssl rand -hex 32
CSRF_SECRET=
